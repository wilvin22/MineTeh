# MineTeh Environment Configuration
# Copy this file to .env and update with your actual values

# Environment: development or production
ENVIRONMENT=development

# Production URL (only used when ENVIRONMENT=production)
PRODUCTION_URL=https://yourdomain.com

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Android App API Configuration
# For development with emulator: http://10.0.2.2/MineTeh/api/v1/
# For development with physical device: http://YOUR_PC_IP/MineTeh/api/v1/
# For production: https://yourdomain.com/api/v1/
ANDROID_API_URL=http://10.0.2.2/MineTeh/api/v1/
